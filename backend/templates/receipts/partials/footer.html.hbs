<footer class="receipt-footer">
  <div class="payment-info">
    <span class="label">{{t 'receipt.paymentMethod'}}:</span>
    <span class="payment-method-display">{{receipt.paymentMethod}}</span>
  </div>

  {{#if receipt.notes}}
  <div class="footer-notes">
    <span class="label">{{t 'receipt.notes'}}:</span>
    <span>{{receipt.notes}}</span>
  </div>
  {{/if}}

  {{#if receipt.legalText}}
  <div class="legal-text">{{receipt.legalText}}</div>
  {{else}}
  <div class="legal-text">
    {{t 'receipt.legalDisclaimer'}}
  </div>
  {{/if}}

  <div class="thank-you-message">
    {{t 'receipt.thankYou'}}
  </div>

  <div class="page-info">
    <span>{{t 'receipt.page'}} <span class="page-number"></span> {{t 'receipt.of'}} <span class="page-count"></span></span>
  </div>
</footer>
